# ===== Postgres =====
POSTGRES_USER=bf
POSTGRES_PASSWORD=bf
POSTGRES_DB=bf_manager
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# 后端从 DATABASE_URL 读取
DATABASE_URL=postgresql+asyncpg://bf:bf@postgres:5432/bf_manager

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== EA 凭据加密密钥 =====
# 生成方式：openssl rand -base64 32
# 生产环境必须替换为强随机值，并通过 Docker secrets 注入
EA_CRED_ENCRYPTION_KEY=ZGV2LW9ubHktY2hhbmdlLW1lLWluLXByb2QtMzJieXQ=

# ===== JWT =====
# 生成方式：openssl rand -hex 32
JWT_SECRET_KEY=dev-only-jwt-secret-change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ===== HTTP 代理（EA API 在部分网络环境需要走代理）=====
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,postgres,redis,backend,web

# ===== CORS =====
ALLOWED_ORIGINS=http://localhost:3000

# ===== 启用的游戏（逗号分隔）=====
ENABLED_GAMES=bf1

# ===== 外部封禁查询 =====
# BFEAC 案件查询需要 API key（按 EA 昵称查询）；BFBAN(gametools) 无需 key。
# 留空时 BFEAC 降级为「无信息」，不影响 BFBAN 与主战绩。
BFEAC_API_KEY=

# 平台 admin 名单不再通过 env 维护。
# 初始 admin 用 CLI 创建：
#   docker compose exec backend python -m app.cli create-admin --username root
# 已存在的 EA 用户提权为 admin：
#   docker compose exec backend python -m app.cli grant-admin --persona <persona_id>

# ===== 日志 =====
LOG_LEVEL=INFO

# ===== 前端配置 =====
BACKEND_API_URL=http://backend:8000
NEXT_PUBLIC_DEFAULT_GAME=bf1
NEXTAUTH_SECRET=dev-only-nextauth-secret-change-me

# ===== 生产环境额外配置 =====
# 域名（Caddy 自动从 Let's Encrypt 签证书）
DOMAIN=bf-manager.example.com

# 镜像 tag（生产部署时锁定）
IMAGE_TAG=latest
