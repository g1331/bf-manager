# 默认所有文本文件用 LF
* text=auto eol=lf

# 二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.tar.gz binary

# 必须用 LF（在 Linux 容器中执行）
*.sh text eol=lf
Dockerfile text eol=lf
Makefile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows 专用脚本
*.bat text eol=crlf
*.ps1 text eol=crlf
