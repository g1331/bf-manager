{
  "name": "@bf-manager/shared-types",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./api": {
      "types": "./src/api.d.ts",
      "default": "./src/api.d.ts"
    }
  },
  "scripts": {
    "generate": "openapi-typescript ${BACKEND_URL:-http://localhost:8000}/api/v1/openapi.json -o src/api.d.ts --enum"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.4"
  }
}
