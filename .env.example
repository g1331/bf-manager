# ===== Postgres =====
POSTGRES_USER=bf
POSTGRES_PASSWORD=bf
POSTGRES_DB=bf_manager
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# 后端从 DATABASE_URL 读取
DATABASE_URL=postgresql+asyncpg://bf:bf@postgres:5432/bf_manager

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== EA 凭据加密密钥 =====
# 生成方式：openssl rand -base64 32
# 生产环境必须替换为强随机值，并通过 Docker secrets 注入
EA_CRED_ENCRYPTION_KEY=ZGV2LW9ubHktY2hhbmdlLW1lLWluLXByb2QtMzJieXRlc2tleQ==

# ===== JWT =====
# 生成方式：openssl rand -hex 32
JWT_SECRET_KEY=dev-only-jwt-secret-change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ===== HTTP 代理（EA API 在部分网络环境需要走代理）=====
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,postgres,redis,backend,web

# ===== CORS =====
ALLOWED_ORIGINS=http://localhost:3000

# ===== 启用的游戏（逗号分隔）=====
ENABLED_GAMES=bf1

# ===== 平台 admin 名单（逗号分隔的 persona_id）=====
# 这些用户每次登录都被强制赋予 role="admin"，可以访问服管权限授予页与全量审计日志。
# 不在此名单内的用户每次登录被降回 role="user"。声明式：env 改了重启生效。
ADMIN_PERSONA_IDS=

# ===== 日志 =====
LOG_LEVEL=INFO

# ===== 前端配置 =====
BACKEND_API_URL=http://backend:8000
NEXT_PUBLIC_DEFAULT_GAME=bf1
NEXTAUTH_SECRET=dev-only-nextauth-secret-change-me

# ===== 生产环境额外配置 =====
# 域名（Caddy 自动从 Let's Encrypt 签证书）
DOMAIN=bf-manager.example.com

# 镜像 tag（生产部署时锁定）
IMAGE_TAG=latest
